{
  "name": "tinymola-agent",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "build:electron": "npm run build && electron-builder",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "start": "tsx server/index.ts",
    "start-public": "npm run build && npx concurrently \"npx tsx server/index.ts\" \"npx -y localtunnel --port 3000\"",
    "tunnel": "npx -y localtunnel --port 3000"
  },
  "dependencies": {
    "@tdesign-react/aigc": "^0.1.0-alpha.1",
    "@tdesign-react/chat": "^1.0.2",
    "@tencent-ai/agent-sdk": "^0.3.43",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0",
    "tdesign-icons-react": "^0.5.0",
    "tdesign-react": "^1.12.0",
    "tsx": "^4.6.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "less": "^4.3.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.2",
    "vite": "^5.0.10"
  },
  "build": {
    "appId": "com.tinymola.agent",
    "productName": "TinyMola 代发管理系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json",
      "data/**/*"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "TinyMola 代发管理"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "public/icon.png"
    }
  }
}
